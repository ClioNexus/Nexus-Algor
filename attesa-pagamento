<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shazam Algor - Generazione Token</title>
    <style>
        body { background-color: #0d0d1a; color: #e0e0e0; font-family: 'Courier New', monospace; margin: 0; display: flex; justify-content: center; align-items: center; height: 100vh; flex-direction: column; overflow: hidden; }
        #loading-screen { display: flex; flex-direction: column; align-items: center; text-align: center; }
        .loader { width: 80px; height: 80px; border: 4px solid #1a1a2e; border-top: 4px solid #800080; border-right: 4px solid #00ffff; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 30px; box-shadow: 0 0 15px #800080; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .pulsing { animation: pulse 1.5s infinite; color: #00ffff; font-size: 1.5em; text-shadow: 0 0 10px #00ffff;}
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } }
        #log-box { margin-top: 20px; font-size: 0.9em; color: #aaa; text-align: left; width: 400px; height: 120px; overflow: hidden; border-left: 2px solid #800080; padding-left: 15px; }
        
        #success-screen { display: none; flex-direction: column; align-items: center; text-align: center; background: rgba(0, 255, 0, 0.05); padding: 40px; border: 1px solid #00ff00; border-radius: 10px; box-shadow: 0 0 30px rgba(0, 255, 0, 0.2); }
        .success-title { color: #00ff00; font-size: 2em; margin-bottom: 10px; text-shadow: 0 0 10px #00ff00; font-family: 'Papyrus', fantasy; }
        .auth-code { font-size: 2.5em; color: #fff; background: #000; padding: 15px 30px; border: 2px dashed #00ffff; border-radius: 8px; letter-spacing: 5px; margin-bottom: 20px; text-shadow: 0 0 5px #fff; }
        .copy-btn { padding: 12px 30px; background: #00ffff; color: #000; font-weight: bold; font-size: 1.1em; border: none; border-radius: 5px; cursor: pointer; transition: 0.3s; text-transform: uppercase; }
        .copy-btn:hover { background: #fff; box-shadow: 0 0 15px #00ffff; }
        #copy-feedback { color: #00ff00; margin-top: 15px; height: 20px; font-weight: bold; }
    </style>
</head>
<body>
    <div id="loading-screen">
        <div class="loader"></div>
        <div class="pulsing">ALLOCAZIONE RISORSE IN CORSO...</div>
        <div id="log-box"></div>
    </div>
    <div id="success-screen">
        <div class="success-title">NODO ALLOCATO CON SUCCESSO</div>
        <p style="color: #ccc; margin-bottom: 30px;">Usa questo codice di autenticazione per autorizzare il cluster:</p>
        <div class="auth-code" id="auth-code-text">X7B9-4F2A-99QW-10PZ</div>
        <button class="copy-btn" onclick="copyAuthCode()">Copia Codice Auth</button>
        <div id="copy-feedback"></div>
    </div>
    <script>
        const logBox = document.getElementById('log-box');
        const msgs = ["> Connessione cloud stabilita...", "> Allocazione Petaflops...", "> Generazione token a 256-bit...", "> Compilazione stringa...", "> VERIFICA COMPLETATA."];
        let i = 0;
        function printLogs() { if (i < msgs.length) { logBox.innerHTML += msgs[i++] + "<br>"; setTimeout(printLogs, 900); } else { setTimeout(() => { document.getElementById('loading-screen').style.display = 'none'; document.getElementById('success-screen').style.display = 'flex'; }, 1000); } }
        window.onload = () => setTimeout(printLogs, 500);
        function copyAuthCode() { navigator.clipboard.writeText(document.getElementById('auth-code-text').innerText).then(() => { document.getElementById('copy-feedback').innerText = "Codice copiato!"; }); }
    </script>
</body>
</html>