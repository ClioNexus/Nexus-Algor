<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shazam Algor - Monitoraggio Traffico</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        body { background-color: #0d0d1a; color: #e0e0e0; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 20px; overflow-x: hidden; }
        #canvas-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; opacity: 0.4; }
        header { text-align: center; margin-bottom: 20px; }
        h1 { font-family: 'Papyrus', fantasy; font-size: 3em; color: #00ffff; text-shadow: 2px 2px 8px #800080; margin: 0; }
        .dashboard-container { max-width: 1000px; margin: 0 auto; background: rgba(13, 13, 26, 0.85); border: 1px solid #800080; border-radius: 10px; padding: 30px; box-shadow: 0 0 20px rgba(128, 0, 128, 0.3); backdrop-filter: blur(5px); }
        .timer-section { text-align: center; padding: 15px; margin-bottom: 30px; background: rgba(255, 0, 0, 0.1); border: 1px dashed #ff0000; border-radius: 8px; }
        .timer-title { color: #ff4444; font-weight: bold; font-size: 1.2em; margin-bottom: 5px; }
        .countdown { font-family: monospace; font-size: 2.5em; color: #ff0000; text-shadow: 0 0 10px #ff0000; }
        .warning-text { color: #ffaa00; font-size: 0.9em; margin-top: 10px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 30px; font-family: monospace; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #2a2a4a; }
        th { color: #00ffff; text-transform: uppercase; }
        tr:hover { background: rgba(0, 255, 255, 0.05); }
        .status-ok { color: #00ff00; }
        .status-error { color: #ff0000; font-weight: bold; animation: blinker 1.5s linear infinite; }
        .row-error { background: rgba(255, 0, 0, 0.15); border-left: 4px solid #ff0000; }
        @keyframes blinker { 50% { opacity: 0.5; } }
        .balance-section { text-align: center; padding: 25px; background: rgba(0, 255, 255, 0.05); border: 1px solid #00ffff; border-radius: 8px; margin-bottom: 20px; }
        .balance-title { color: #00ffff; font-size: 1.2em; letter-spacing: 2px; margin-bottom: 10px; }
        .balance-amount { font-size: 3.5em; color: #00ff00; text-shadow: 0 0 15px #00ff00; font-family: monospace; font-weight: bold; margin: 10px 0; }
        .lock-warning { color: #ff4444; margin-top: 15px; padding: 10px; border: 1px solid #ff4444; display: inline-block; border-radius: 5px; background: rgba(255,0,0,0.1); }
        .action-btn { display: block; width: 100%; max-width: 400px; margin: 0 auto; padding: 15px; background: #800080; color: white; font-weight: bold; font-size: 1.1em; border: 1px solid #ff00ff; border-radius: 5px; cursor: pointer; transition: 0.3s; text-transform: uppercase; }
        .action-btn:hover { background: #ff00ff; color: #000; box-shadow: 0 0 15px #ff00ff; }
    </style>
</head>
<body>
    <div id="canvas-bg"></div>
    <header><h1>Shazam Algor</h1></header>
    <div class="dashboard-container">
        <div class="timer-section">
            <div class="timer-title">TEMPO LIMITE COMPLETAMENTO TASK:</div>
            <div class="countdown" id="timer-display">22:00:00</div>
            <div class="warning-text">Rischio critico: In caso di mancato smaltimento del traffico dati, l'intero cluster verrà resettato.</div>
        </div>
        <table>
            <thead><tr><th>ID Algoritmo</th><th>Traffico Gestito</th><th>Stato Macinazione</th></tr></thead>
            <tbody>
                <tr><td>ALG-77X-ALPHA</td><td>842.5 GB</td><td class="status-ok">🟢 Completato (100%)</td></tr>
                <tr><td>ALG-32B-OMEGA</td><td>610.2 GB</td><td class="status-ok">🟢 Completato (100%)</td></tr>
                <tr class="row-error"><td>ALG-404-CRITICAL</td><td>12.4 GB / 1.2 TB</td><td class="status-error">🔴 BLOCCATO: Insufficienza Potenza</td></tr>
                <tr><td>ALG-11A-SIGMA</td><td>In attesa...</td><td style="color: #aaa;">⚪ Standby (In attesa)</td></tr>
            </tbody>
        </table>
        <div class="balance-section">
            <div class="balance-title">Totale Generato</div>
            <div class="balance-amount" id="balance-display">€ 4.258,40</div>
            <div class="lock-warning">⚠️ ANOMALIA DI SISTEMA: Risolvere il blocco di calcolo.</div>
        </div>
        <button class="action-btn" onclick="window.location.href='scelta-pacchetti.html'">Esegui Override di Emergenza</button>
    </div>
    <script>
        const container = document.getElementById('canvas-bg'); const scene = new THREE.Scene(); const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000); const renderer = new THREE.WebGLRenderer({ alpha: true }); renderer.setSize(window.innerWidth, window.innerHeight); container.appendChild(renderer.domElement);
        const geo = new THREE.BufferGeometry(); const count = 15000; const pos = new Float32Array(count * 3); const col = new Float32Array(count * 3);
        for(let i=0; i<count*3; i+=3){ const r=3, t=2*Math.PI*Math.random(), p=Math.acos(2*Math.random()-1); pos[i]=r*Math.sin(p)*Math.cos(t); pos[i+1]=r*Math.sin(p)*Math.sin(t); pos[i+2]=r*Math.cos(p); if(Math.random()>0.5){ col[i]=0; col[i+1]=1; col[i+2]=1; } else { col[i]=0.5; col[i+1]=0; col[i+2]=0.5; } }
        geo.setAttribute('position', new THREE.BufferAttribute(pos, 3)); geo.setAttribute('color', new THREE.BufferAttribute(col, 3)); const mat = new THREE.PointsMaterial({ size: 0.015, vertexColors: true, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false }); const mesh = new THREE.Points(geo, mat); scene.add(mesh); camera.position.z = 4;
        let time = 0; function animate() { requestAnimationFrame(animate); mesh.rotation.y += 0.001; time += 0.01; renderer.render(scene, camera); } animate();

        let tSec = 22*3600; setInterval(()=>{ let h = Math.floor(tSec/3600), m = Math.floor((tSec%3600)/60), s = tSec%60; document.getElementById('timer-display').innerText = `${h<10?'0'+h:h}:${m<10?'0'+m:m}:${s<10?'0'+s:s}`; if(tSec>0)tSec--; }, 1000);
        let bal = 4258.40; setInterval(()=>{ bal += parseFloat((Math.random()*0.15).toFixed(2)); document.getElementById('balance-display').innerText = `€ ${bal.toLocaleString('it-IT',{minimumFractionDigits:2,maximumFractionDigits:2})}`; }, 3500);
    </script>
</body>
</html>